# kingdom-builder-web 生產環境設定（.199 統一閘道）
# LIDS SSO — 與 hd-portal .env.production 完全一致（同 client，共享 sessionStorage）
# ⚠️ 與 hd-portal authority 一致 = localhost:8073（LIDS server issuer dev default，閘道 /lids 已 adapt）。
# sessionStorage key `oidc.user:${ISSUER}:${CLIENT_ID}` 必須與 portal 寫入完全相同才讀得到共享 session。
VITE_LIDS_ISSUER=http://localhost:8073
VITE_LIDS_METADATA_URL=https://192.168.50.199:8443/lids/.well-known/openid-configuration
VITE_LIDS_CLIENT_ID=hd-portal-199
VITE_LIDS_SCOPE=openid profile email
