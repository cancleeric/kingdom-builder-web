      "welcome": {
        "title": "歡迎來到王國建造者！",
        "description": "本教學會帶你了解遊戲基礎。王國建造者是一款在六角格王國中建立聚落的策略遊戲。點擊「下一步」繼續。"
      },
      "board": {
        "title": "遊戲棋盤",
        "description": "棋盤由不同地形的六角格組成：草地 🌿、森林 🌲、沙漠 🏜️、花地 🌸、峽谷 🪨、水域 💧，以及不可通行的山脈 ⛰️。你只能在可建造地形上放置聚落（不可在水域或山脈）。"
      },
      "castles": {
        "title": "城堡與地點板塊",
        "description": "黃色城堡 🏰 六角格是特殊計分點，遊戲結束時與城堡相鄰可得額外分數。特殊地點板塊格（農場、綠洲、高塔…）在你相鄰放置聚落時會給予強力能力。"
      },
      "terrain-card": {
        "title": "地形卡",
        "description": "每回合開始時你會抽一張地形卡，決定本回合 3 個聚落必須放置的地形。你不能自行選擇，由卡牌決定！點擊「抽地形卡」開始回合。"
      },
      "placement-rules": {
        "title": "放置規則",
        "description": "你必須在卡牌指定地形上放置恰好 3 個聚落。若你已有聚落鄰接可放置地形，就必須放在既有聚落旁（相鄰規則）。高亮格子顯示合法位置。"
      },
      "location-tile-gain": {
        "title": "獲得地點板塊",
        "description": "當你把聚落放在地點板塊六角格旁邊時，會自動獲得該板塊並加入收藏。地點板塊每回合可使用一次，進行如移動聚落等特殊操作。"
      },
      "objectives": {
        "title": "目標卡",
        "description": "遊戲開始會翻開三張目標卡，描述特殊計分條件，例如最大連通群、靠近城堡等。所有玩家都使用相同目標！"
      },
      "turn-flow": {
        "title": "回合流程",
        "description": "1️⃣ 抽地形卡 → 2️⃣ 在對應地形放置 3 個聚落（遵守相鄰規則）→ 3️⃣ 結束回合。結束前可選擇使用地點板塊能力。重複直到聚落放完！"
      },
      "scoring": {
        "title": "計分與勝利",
        "description": "當所有玩家放完 40 個聚落後遊戲結束。分數由城堡相鄰、目標卡與額外板塊加成計算。分數最高者獲勝！"
      },
      "done": {
        "title": "你已準備好開始！",
