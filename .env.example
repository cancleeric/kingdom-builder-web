# ============================================================
# Kingdom Builder Web — 環境變數範例
# 複製此檔案為 .env.local（開發）或 .env.production（生產）
# ============================================================

# Base URL path for deployment (e.g. /kingdom-builder-web/ for GitHub Pages)
# Leave as / for root deployments (Vercel, custom domain)
VITE_BASE_PATH=/

# Application environment
VITE_APP_ENV=development

# Feature flags
VITE_ENABLE_AI=true
VITE_ENABLE_MULTIPLAYER=false

# Analytics (optional)
# VITE_GA_ID=G-XXXXXXXXXX
